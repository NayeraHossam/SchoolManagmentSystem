<odoo>
    <data>
     <record id="student_profile_view_tree" model="ir.ui.view">
            <field name="name">student.profile.tree</field>
        <field name="model">student.profile</field>
        <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="student_id"/>
                    <field name="total_hours"/>
                </tree>
        </field>
        </record>

    <record id="student_profile_view_form" model="ir.ui.view">
            <field name="name">student.profile.form</field>
        <field name="model">student.profile</field>
        <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="student_id"/>
                        <field name="total_hours"/>
                        <field name="gpa"/>
                    </group>
                    <notebook>
                        <page string="Course IDs">
                                <tree editable="bottom">
                                    <field name="course_ids"/>
                                </tree>

                        </page>
                    </notebook>

                </form>
        </field>
        </record>
    </data>
    <record id="student_profile_action" model="ir.actions.act_window">
        <field name="name">Student profile</field>
        <field name="res_model">student.profile</field>
    </record>

    <menuitem
            id="student_profile_item"
            name="Student Profile"
            parent="student_profile_menu"
            action="student_profile_action"
    />
</odoo>