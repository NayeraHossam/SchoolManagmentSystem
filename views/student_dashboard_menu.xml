<odoo>

    <record id="view_student_profile_kanban" model="ir.ui.view">
        <field name="name">student.profile.kanban</field>
        <field name="model">student.profile</field>
        <field name="arch" type="xml">

            <kanban class="o_kanban_small_column">

                <field name="name"/>
                <field name="student_id"/>
                <field name="total_hours"/>


                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">

                            <strong>
                                <field name="name"/>
                            </strong>

                            <div>
                                 StudentID:
                                <field name="student_id"/>
                            </div>
                            <div>
                                 Credit Hours:
                                <field name="total_hours"/>
                            </div>


                        </div>
                    </t>
                </templates>

            </kanban>

        </field>
    </record>


    <record id="student_dashboard_action" model="ir.actions.act_window">
        <field name="name">Student Dashboard</field>
        <field name="res_model">student.profile</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>


    <menuitem id="student_dashboard_menu"
              name="Student Dashboard"
              sequence="1"/>

    <menuitem id="student_dashboard_item"
              name="Dashboard"
              parent="student_dashboard_menu"
              action="student_dashboard_action"/>

</odoo>