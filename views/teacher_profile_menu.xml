<odoo>
    <data>
        <record id="group_teacher" model="res.groups">
            <field name="name">Teacher</field>
        </record>
     <record id="teacher_profile_view_tree" model="ir.ui.view">
            <field name="name">teacher.profile.tree</field>
        <field name="model">teacher.profile</field>
        <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="department"/>
                    <field name="course_ids"/>
                </tree>
        </field>
        </record>

    <record id="teacher_profile_view_form" model="ir.ui.view">
            <field name="name">teacher.profile.form</field>
        <field name="model">teacher.profile</field>
        <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="name"/>
                        <field name="teacherid"/>
                        <field name="department"/>
                    </group>
                    <notebook>
                        <page string="Courses">
                                <tree editable="bottom">
                                    <field name="course_ids"/>
                                </tree>
                        </page>
                    </notebook>

                </form>
        </field>
        </record>
    </data>
    <record id="teacher_profile_action" model="ir.actions.act_window">
        <field name="name">Teacher profile</field>
        <field name="res_model">teacher.profile</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem
            id="teacher_profile_item"
            name="Teacher Profile"
            parent="teacher_profile_menu"
            action="teacher_profile_action"
    />
</odoo>